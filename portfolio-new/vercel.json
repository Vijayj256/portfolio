{
    "version": 2,
    "builds": [
        {
            "src": "/index.js",
            "use": "@vercel/node",
            "config": {
                "distDir": "client/build"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}